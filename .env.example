# Supabase app configuration
# Replace values with your own Supabase project settings.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_api_key

# Optional: override the cold-start staleness threshold (milliseconds).
# Default is 4 hours. Example: 86400000 = 24 hours.
# VITE_STALENESS_THRESHOLD_MS=14400000
